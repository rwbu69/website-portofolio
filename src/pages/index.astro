---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import { getFeaturedProjects } from "../data/projects";
import { getCollection } from "astro:content";
import { identity, experience, allSkillsFlat } from "../data/profile";
import TechIcon from "../components/react/TechIcon";

const featuredProjects = getFeaturedProjects();
const allPosts = await getCollection("blog");
const latestPosts = allPosts
  .sort(
    (a, b) =>
      new Date(b.data.publishDate).valueOf() -
      new Date(a.data.publishDate).valueOf(),
  )
  .slice(0, 2);

const skills = allSkillsFlat;
const currentStatus =
  experience.find((exp) => exp.role.toLowerCase().includes("freelance"))
    ?.duration || "Available for work";
---

<Layout title={`RWBU | ${identity.role}`}>
  <Navbar />

  <main class="max-w-6xl mx-auto px-6 py-12 w-full flex-grow">
    <!-- Log Entry Header -->
    <header class="mb-16 border-l-2 border-tosca pl-6">
      <div
        class="flex items-center gap-3 text-sm text-text-muted mb-2 font-mono"
      >
        <span class="text-tosca">DATE</span>
        <span>{new Date().toISOString().split("T")[0]}</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">
        Hello, I'm <span class="text-pink">{identity.alias}</span>.
      </h1>
      <p class="text-lg md:text-xl text-text-muted max-w-2xl leading-relaxed">
        {identity.bioShort}
      </p>

      <div class="mt-6 flex items-center gap-3 font-mono text-sm">
        <div
          class="flex items-center gap-2 px-3 py-1 bg-green/10 text-green rounded-sm border border-green/20"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green opacity-75"
            ></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green"
            ></span>
          </span>
          {currentStatus.toUpperCase()}
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Left Column: Skills & Recent Posts -->
      <div class="space-y-12">
        <section>
          <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
            <span class="text-tosca font-mono">#</span> Stack ^w^
          </h2>
          <div class="flex flex-wrap gap-2">
            {
              skills.map((skill) => (
                <span class="px-3 py-1.5 text-sm bg-[#0f172a] border border-[#1a2333] text-text-main rounded-sm hover:border-pink hover:text-pink transition-colors flex items-center gap-2">
                  <TechIcon tech={skill} className="w-4 h-4" />
                  {skill}
                </span>
              ))
            }
          </div>
        </section>

        <section>
          <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
            <span class="text-tosca font-mono">#</span> Blogs
          </h2>
          <div class="space-y-6">
            {
              latestPosts.map((post) => (
                <article class="group">
                  <p class="text-xs font-mono text-text-muted mb-1">
                    {post.data.publishDate}
                  </p>
                  <h3 class="text-lg font-medium mb-1 group-hover:text-tosca transition-colors">
                    <a href={`/blog/${post.id}`}>{post.data.title}</a>
                  </h3>
                  <p class="text-sm text-text-muted line-clamp-2">
                    {post.data.excerpt}
                  </p>
                </article>
              ))
            }
            <a
              href="/blog"
              class="inline-flex items-center gap-2 text-sm text-tosca hover:text-pink transition-colors font-mono mt-4"
            >
              View all blogs ->
            </a>
          </div>
        </section>
      </div>

      <!-- Right Column: Featured Projects -->
      <section>
        <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
          <span class="text-tosca font-mono">#</span> Projects
        </h2>
        <div class="space-y-6">
          {
            featuredProjects.map((project) => (
              <div class="p-5 bg-[#0f172a]/50 border border-[#1a2333] hover:border-tosca transition-colors rounded-sm group relative overflow-hidden">
                <div class="absolute top-0 right-0 w-16 h-16 bg-tosca/5 rounded-bl-full -z-10 group-hover:bg-tosca/10 transition-colors" />
                <div class="flex justify-between items-start mb-2">
                  <h3 class="text-lg font-medium group-hover:text-tosca transition-colors">
                    {project.title}
                  </h3>
                  <span
                    class={`text-xs font-mono px-2 py-0.5 rounded-sm border ${project.status === "completed" || project.status === "live" ? "text-green border-green/30 bg-green/10" : "text-yellow border-yellow/30 bg-yellow/10"}`}
                  >
                    {project.status}
                  </span>
                </div>
                <p class="text-sm text-text-muted mb-4">
                  {project.description}
                </p>
                <div class="flex flex-wrap gap-2 mb-4">
                  {project.tech.length > 0 ? (
                    project.tech.map((t) => (
                      <span
                        class="flex items-center gap-1.5 text-xs text-text-muted bg-[#050505] px-2 py-1 rounded-sm border border-[#1a2333]"
                        title={t}
                      >
                        <TechIcon tech={t} className="w-3 h-3" />
                        <span>{t}</span>
                      </span>
                    ))
                  ) : (
                    <span class="text-xs text-text-muted opacity-50 bg-[#050505] px-2 py-1 rounded-sm border border-[#1a2333]">
                      [Tech stack TBD]
                    </span>
                  )}
                </div>
                <div class="flex gap-4 text-sm font-mono">
                  {project.demoLink && (
                    <a
                      href={project.demoLink}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-tosca hover:text-pink transition-colors"
                    >
                      [ Demo ]
                    </a>
                  )}
                  {project.repoLink && (
                    <a
                      href={project.repoLink}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-text-muted hover:text-pink transition-colors"
                    >
                      [ Source ]
                    </a>
                  )}
                </div>
              </div>
            ))
          }
          <a
            href="/projects"
            class="inline-flex items-center gap-2 text-sm text-tosca hover:text-pink transition-colors font-mono mt-4"
          >
            View all projects ->
          </a>
        </div>
      </section>
    </div>
  </main>
</Layout>
