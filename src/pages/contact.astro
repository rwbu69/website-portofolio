---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { EnvelopeIcon, MapPinIcon } from '@heroicons/react/24/outline';
import { SocialIcons } from '../components/react/SocialIcons'; // Will create this next
---

<Layout title="RWBU | Contact">
  <Navbar />
  
  <main class="max-w-6xl mx-auto px-6 py-12 w-full flex-grow">
    <header class="mb-12 border-l-2 border-tosca pl-6">
      <h1 class="text-3xl md:text-4xl font-bold mb-4 tracking-tight">
        <span class="text-tosca font-mono">/</span>contact
      </h1>
      <p class="text-lg text-text-muted max-w-2xl">
        Let's build something great together. Send me a message or find me on the web.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Contact Form -->
      <section class="bg-[#0f172a]/30 border border-[#1a2333] p-6 rounded-sm">
        <form class="space-y-6" action="mailto:sebastianhutagalung69@gmail.com" method="POST" enctype="text/plain">
          <div class="space-y-2">
            <label for="name" class="block text-sm font-mono text-text-muted">
              <span class="text-pink">></span> Name
            </label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              required
              class="w-full bg-[#050505] border border-[#1a2333] rounded-sm px-4 py-2.5 text-text-main focus:outline-none focus:border-tosca transition-colors"
            />
          </div>
          
          <div class="space-y-2">
            <label for="email" class="block text-sm font-mono text-text-muted">
              <span class="text-pink">></span> Email
            </label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required
              class="w-full bg-[#050505] border border-[#1a2333] rounded-sm px-4 py-2.5 text-text-main focus:outline-none focus:border-tosca transition-colors"
            />
          </div>
          
          <div class="space-y-2">
            <label for="message" class="block text-sm font-mono text-text-muted">
              <span class="text-pink">></span> Message
            </label>
            <textarea 
              id="message" 
              name="message" 
              rows="5"
              required
              class="w-full bg-[#050505] border border-[#1a2333] rounded-sm px-4 py-2.5 text-text-main focus:outline-none focus:border-tosca transition-colors resize-y"
            ></textarea>
          </div>
          
          <button 
            type="submit"
            class="w-full bg-tosca/10 border border-tosca text-tosca hover:bg-tosca hover:text-[#050505] font-mono py-3 rounded-sm transition-colors"
          >
            SEND
          </button>
        </form>
      </section>
      
      <!-- Contact Info -->
      <section class="space-y-8">
        <div>
          <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
            <span class="text-tosca font-mono">#</span> Direct_Line
          </h2>
            <div class="flex items-center gap-4 p-4 border border-[#1a2333] rounded-sm">
              <div class="bg-[#0f172a] p-2 rounded-sm">
                <MapPinIcon class="w-6 h-6" />
              </div>
              <div>
                <p class="text-sm text-text-muted font-mono mb-1">Location</p>
                <p>Yogyakarta, Indonesia</p>
              </div>
            </div>
        </div>
        
        <div>
          <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
            <span class="text-tosca font-mono">#</span> Socials
          </h2>
          <SocialIcons client:visible />
        </div>
      </section>
    </div>
  </main>
</Layout>
