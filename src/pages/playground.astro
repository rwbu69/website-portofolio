---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PlaygroundTabs from '../components/react/PlaygroundTabs';
---

<Layout title="RWBU | Code Playground">
  <Navbar />
  
  <main class="max-w-6xl mx-auto px-6 py-12 w-full flex-grow flex flex-col">
    <header class="mb-8 border-l-2 border-tosca pl-6">
      <h1 class="text-3xl md:text-4xl font-bold mb-4 tracking-tight">
        <span class="text-tosca font-mono">/</span>playground
      </h1>
      <p class="text-lg text-text-muted max-w-2xl">
        A fun interactive zone. Play around with the fake terminal or write some JavaScript in the sandbox.
      </p>
    </header>

    <div class="flex-grow">
      <PlaygroundTabs client:load />
    </div>
  </main>
</Layout>
