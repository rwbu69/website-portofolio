---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="404 | Command Not Found">
  <Navbar />
  
  <main class="max-w-4xl mx-auto px-6 py-24 w-full flex-grow flex flex-col items-center justify-center text-center">
    <div class="inline-block p-8 bg-[#0f172a]/30 border border-[#1a2333] rounded-sm relative">
      <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-pink via-tosca to-green"></div>
      
      <div class="text-6xl font-bold font-mono text-tosca mb-4 flex items-center justify-center gap-4">
        <span>[</span> 404 <span>]</span>
      </div>
      
      <h1 class="text-2xl md:text-3xl font-bold mb-4">
        Command Not Found
      </h1>
      
      <p class="text-text-muted mb-8 font-mono max-w-md">
        > The page you are looking for has been moved, deleted, or never existed in the first place.
      </p>
      
      <div class="flex gap-4 justify-center">
        <a href="/" class="px-6 py-2 bg-tosca/10 border border-tosca text-tosca hover:bg-tosca hover:text-[#050505] font-mono rounded-sm transition-colors">
          cd ~
        </a>
        <button onclick="window.history.back()" class="px-6 py-2 bg-transparent border border-[#1a2333] text-text-muted hover:border-pink hover:text-pink font-mono rounded-sm transition-colors">
          cd ..
        </button>
      </div>
    </div>
  </main>
</Layout>
